          </div>
          <div style="display:flex;gap:1rem;align-items:start;cursor:pointer;transition:all .2s;" onmouseover="this.style.transform='translateX(6px)'" onmouseout="this.style.transform='translateX(0)'">
            <span style="font-size:2rem;">💰</span>

<!-- ==================== CONTEXT DISASTER ==================== -->
<section id="defects" class="slide">
  <div class="slide-content" style="max-width:1000px;">
    <div class="reveal">
      <div style="display:flex;align-items:center;gap:.8rem;margin-bottom:.5rem;">
        <span style="background:rgba(255,214,10,.15);color:var(--warn);padding:4px 12px;border-radius:100px;font-size:12px;font-weight:600;">案例 5</span>
        <h2 style="font-size:2rem;font-weight:800;">上下文灾难 — 对话太长，忘了前面的</h2>
      </div>
      <p style="color:var(--muted);font-size:.9rem;margin-bottom:1.5rem;">AI 的记忆不是无限的。任务越复杂、对话越长，越容易在早期步骤中遗漏细节 ↓</p>
      <button class="interact-btn" id="ctx-btn" onclick="playContextDemo()" style="background:rgba(255,214,10,.1);border-color:rgba(255,214,10,.3);color:var(--warn);">▶ 点击演示</button>
      <button class="replay-btn" id="ctx-replay" onclick="resetDemo('ctx-btn','ctx-replay')">🔄 重置演示</button>
    </div>
    <!-- Context bar - interactive -->
    <div style="margin-top:1.5rem;">
      <div style="font-size:12px;color:var(--muted);margin-bottom:.5rem;font-weight:600;">上下文空间分配</div>
      <div class="ctx-bar" id="ctx-bar">
        <div class="ctx-seg" style="width:5%;background:var(--accent);">
          <span class="label" style="color:#fff;font-size:9px;">指令</span>
        </div>
        <div class="ctx-seg" style="width:25%;background:rgba(74,158,255,.6);">
          <span class="label" style="color:#fff;font-size:9px;">工具列表</span>
        </div>
        <div class="ctx-seg" style="width:30%;background:rgba(255,255,255,.15);">
          <span class="label" style="color:#fff;font-size:9px;">记忆</span>
        </div>
        <div class="ctx-seg" style="width:20%;background:rgba(255,255,255,.08);">
          <span class="label" style="color:var(--fg);font-size:9px;">系统</span>
        </div>
        <div class="ctx-seg" style="width:20%;background:rgba(255,255,255,.05);">
          <span class="label" style="color:var(--fg);font-size:9px;">Skills</span>
        </div>
      </div>
      <div style="margin-top:.5rem;font-size:11px;color:var(--muted);line-height:1.7;display:grid;grid-template-columns:repeat(5,1fr);gap:.3rem;">
        <div style="text-align:center;"><span style="color:var(--accent);font-weight:700;">5%</span><br>用户的修改指令</div>
        <div style="text-align:center;"><span style="color:rgba(74,158,255,.9);font-weight:700;">25%</span><br>工具描述</div>
        <div style="text-align:center;"><span style="font-weight:700;">30%</span><br>记忆+对话历史</div>
        <div style="text-align:center;"><span style="font-weight:700;">20%</span><br>系统提示</div>
        <div style="text-align:center;"><span style="font-weight:700;">20%</span><br>Skill 内容</div>
      </div>
    </div>
    <!-- Task flow -->
    <!-- chat bubbles injected by JS -->
    <div style="margin-top:1rem;" id="ctx-chat-wrap"></div>
    <!-- Result -->
    <div id="ctx-result" style="display:none;margin-top:1.5rem;">
      <div class="danger-card">
        <h4 style="font-weight:600;margin-bottom:.5rem;">🧠 为什么会这样？</h4>
        <p style="color:var(--muted);font-size:.9rem;line-height:1.8;">AI 的「上下文窗口」就像一张有限大小的便签纸。任务链越长、修改指令越多，工具描述、系统提示、历史消息越积越多——<strong style="color:var(--fg);">早期录入的数据就会被「挤」到注意力边缘</strong>，最终被遗漏。这不是 bug，是当前所有大模型的固有限制。</p>
        <div style="display:flex;gap:1.5rem;margin-top:1rem;flex-wrap:wrap;">
          <div style="background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:12px;padding:.8rem 1rem;flex:1;min-width:140px;text-align:center;">
            <div style="font-size:1.5rem;font-weight:900;color:var(--danger);">~128K</div>
            <div style="font-size:11px;color:var(--muted);margin-top:.2rem;">典型上下文窗口</div>
          </div>
          <div style="background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:12px;padding:.8rem 1rem;flex:1;min-width:140px;text-align:center;">
            <div style="font-size:1.5rem;font-weight:900;color:var(--warn);">60-70%</div>
            <div style="font-size:11px;color:var(--muted);margin-top:.2rem;">被系统提示/工具占用</div>
          </div>
          <div style="background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:12px;padding:.8rem 1rem;flex:1;min-width:140px;text-align:center;">
            <div style="font-size:1.5rem;font-weight:900;color:var(--accent);">~30%</div>
            <div style="font-size:11px;color:var(--muted);margin-top:.2rem;">真正留给对话的空间</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ==================== SKILLS ==================== -->
<section class="slide" style="background:var(--bg2);">

<!-- ==================== PARADIGM SHIFT ==================== --> -->
<section class="slide">
  <div class="slide-content" style="max-width:1000px;">
    <div class="reveal">
      <p class="section-label" data-i18n="sec-paradigm-label">范式转变</p>
      <h2 style="font-size:2.5rem;font-weight:800;margin-bottom:1.5rem;" data-i18n="sec-paradigm-title">从 App 到 Agent</h2>
      <p class="serif" style="font-size:1.1rem;color:var(--muted);margin-bottom:2.5rem;max-width:700px;line-height:2;">过去我们打开一个 App，学习它的界面，适应它的规则。现在，你只需要<b style="color:var(--fg);">说出你想要什么</b>，Agent 帮你搞定一切。</p>
    </div>
    <div class="reveal two-col" style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;">
      <div class="danger-card" style="text-align:center;">
        <div style="font-size:3rem;margin-bottom:1rem;">📱</div>
        <h3 style="font-weight:700;margin-bottom:1rem;font-size:1.3rem;color:var(--danger);">App 时代</h3>
        <p style="color:var(--muted);font-size:.9rem;line-height:1.8;">打开 PowerPoint → 选模板 → 调版式 → 插图片 → 对齐文字 → 调字体大小 → 发现布局不对 → 重新排……<br><br><b style="color:var(--fg);">你花 80% 的时间在和软件较劲</b>，只有 20% 在真正准备内容。</p>
      </div>
      <div class="success-card" style="text-align:center;">
        <div style="font-size:3rem;margin-bottom:1rem;">🤖</div>
        <h3 style="font-weight:700;margin-bottom:1rem;font-size:1.3rem;color:var(--success);">Agent 时代</h3>
        <p style="color:var(--muted);font-size:.9rem;line-height:1.8;">「我明天有个英语课 pre，主题是大语言模型，帮我准备演讲材料。」<br><br>Agent 直接生成一个<b style="color:var(--fg);">精美的交互式网页</b>——动画、排版、内容一应俱全。<br><br><b style="color:var(--success);">比 PPT 更灵活，比 Keynote 更自由。</b></p>
      </div>
    </div>
    <div class="reveal" style="margin-top:2rem;">
      <div style="background:rgba(255,107,53,.04);border:1px solid rgba(255,107,53,.15);border-radius:16px;padding:1.5rem 2rem;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
        <div style="font-size:2.5rem;">💡</div>
        <div>
          <p style="font-size:1rem;font-weight:600;margin-bottom:.3rem;">真实案例</p>
          <p style="color:var(--muted);font-size:.9rem;line-height:1.8;">本页面就是一个 Agent 生成的网页。没有用任何可视化编辑器，没有拖拽排版——全程由 AI 理解需求后直接编写 HTML/CSS/JS。<br>这份「演讲材料」本身就是「从 App 到 Agent」最好的证明。</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ==================== VERDICT ==================== -->
<section id="verdict" class="slide" style="background:var(--bg2);">
  <div class="slide-content" style="text-align:center;max-width:900px;">
    <div class="reveal">
      <p class="section-label" data-i18n="sec-verdict-label">总结</p>
      <h2 style="font-size:2.8rem;font-weight:800;margin-bottom:2.5rem;" data-i18n="sec-verdict-title">里程碑，不是魔法</h2>
    </div>
    <div class="reveal two-col" style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-bottom:2.5rem;">
      <div class="success-card" style="text-align:left;">
        <h3 style="font-weight:700;margin-bottom:1rem;color:var(--success);">✅ 擅长</h3>
        <ul style="color:var(--muted);font-size:.95rem;list-style:none;display:flex;flex-direction:column;gap:.5rem;">
          <li>✓ 简单重复的日常杂活</li><li>✓ 文件整理和管理</li><li>✓ 信息搜索和下载</li><li>✓ 24小时待命的AI管家</li><li>✓ 多设备统一控制</li>
        </ul>
      </div>
      <div class="danger-card" style="text-align:left;">
        <h3 style="font-weight:700;margin-bottom:1rem;color:var(--danger);">❌ 做不到</h3>
        <ul style="color:var(--muted);font-size:.95rem;list-style:none;display:flex;flex-direction:column;gap:.5rem;">
          <li>✗ 惊天动地的大工程</li><li>✗ 步骤极多的链式任务</li><li>✗ 需要长期记忆保持</li><li>✗ 安全敏感的操作</li><li>✗ 100%稳定可靠的输出</li>
        </ul>
      </div>
    </div>
    <div class="reveal">
      <div style="border:1px solid var(--border);border-radius:16px;padding:2rem;background:rgba(255,107,53,.03);border-top:3px solid var(--accent);">
        <p class="serif" style="font-size:1.2rem;line-height:2;">OpenClaw不是魔法，把它拆开来每个步骤都不过如此。但有时候<strong style="color:var(--fg);">把现有的东西排列组合，再加点新点子，神奇的事情就发生了。</strong></p>
        <cite style="display:block;margin-top:.8rem;color:var(--muted);font-size:.9rem;font-style:normal;">——— Peter</cite>
        <div style="margin-top:3rem;background:linear-gradient(135deg,rgba(255,107,53,.08),rgba(255,159,28,.08));border:2px solid rgba(255,107,53,.3);border-radius:24px;padding:2.5rem 3rem;text-align:center;box-shadow:0 0 60px rgba(255,107,53,.12),0 0 120px rgba(255,107,53,.06);">
          <p class="serif" style="font-size:1.6rem;line-height:2;font-weight:600;color:var(--fg);">OpenClaw 爆火的原因<br>是激发了人们对于类似 <span style="color:var(--accent);font-weight:800;">贾维斯</span> 的 <span style="color:var(--accent);font-weight:800;">AGI 智能体</span>的幻想</p>
          <p style="font-size:1.3rem;color:var(--muted);margin-top:1rem;">🤖 贾维斯 — 源自电影《<span style="color:var(--accent);font-weight:700;">钢铁侠</span>》</p>
        </div>
    </div>
  </div>
</section>

<!-- ==================== CLOSING ==================== -->
<section class="slide" style="min-height:100vh;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(255,107,53,.08) 0%,transparent 70%);pointer-events:none;"></div>
  <div class="slide-content" style="text-align:center;position:relative;z-index:1;max-width:800px;">
    <div class="reveal"><span style="font-size:5rem;">🦞</span></div>
    <div class="reveal">
      <h2 style="font-size:3rem;font-weight:900;margin:1.5rem 0;line-height:1.3;">欢迎来到<span style="background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;">智能体的时代</span></h2>
    </div>
    <div class="reveal">
      <p class="serif" style="font-size:1.2rem;color:var(--muted);margin:1rem auto;max-width:550px;line-height:2;">在这个极客时代，技术不但是大公司的特权。只要愿意开始，<strong style="color:var(--fg);">每个人都可以拥有属于自己的贾维斯。</strong></p>
    </div>
    <div class="reveal" style="margin-top:2.5rem;display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="https://openclaw.ai" target="_blank" class="cta-btn">OpenClaw →</a>
      <a href="https://bigmodel.cn/glm-coding" target="_blank" class="cta-btn cta-btn-outline">智谱 AI</a>
      <a href="https://clawhub.ai" target="_blank" class="cta-btn cta-btn-outline">Skills</a>
    </div>
    <p style="color:var(--muted);font-size:11px;margin-top:3rem;">OpenClaw 🦞 MIT License</p>
  </div>
</section>

<script>
// ======== SCROLL REVEAL ========
const obs=new IntersectionObserver(e=>{e.forEach(en=>{if(en.isIntersecting)en.target.classList.add('visible')})},{threshold:.1,rootMargin:'0px 0px -50px 0px'});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// ======== BAR CHART ANIMATION ========
const barObs=new IntersectionObserver(e=>{e.forEach(en=>{if(en.isIntersecting){en.target.querySelectorAll('.bar-anim').forEach(bar=>{bar.style.width=bar.dataset.width});barObs.unobserve(en.target)}})},{threshold:.3});
document.querySelectorAll('.reveal').forEach(el=>{if(el.querySelector('.bar-anim'))barObs.observe(el)});

// ======== PROGRESS BAR ========
window.addEventListener('scroll',()=>{const h=document.documentElement.scrollHeight-window.innerHeight;const p=(window.scrollY/h)*100;document.getElementById('progress').style.width=p+'%';document.getElementById('nav').classList.toggle('scrolled',window.scrollY>50)});

// ======== SMOOTH ANCHOR ========
document.querySelectorAll('a[href^="#"]').forEach(a=>{a.addEventListener('click',e=>{e.preventDefault();const t=document.querySelector(a.getAttribute('href'));if(t)t.scrollIntoView({behavior:'smooth',block:'start'})})});

// ======== STAT COUNTER ========
const statObs=new IntersectionObserver(e=>{e.forEach(en=>{if(en.isIntersecting){const el=en.target;const target=parseInt(el.dataset.target);const suffix=el.dataset.suffix||'';let current=0;const step=Math.ceil(target/40);const timer=setInterval(()=>{current=Math.min(current+step,target);el.textContent=current.toLocaleString()+suffix;if(current>=target)clearInterval(timer)},30);statObs.unobserve(el)}})},{threshold:.5});
document.querySelectorAll('.stat-number[data-target]').forEach(el=>statObs.observe(el));

// ======== DYNAMIC DEMO ========
let demoRunning=false;
function runDemo(){if(demoRunning)return;demoRunning=true;const steps=document.querySelectorAll('.demo-node');const btn=document.getElementById('demo-btn');const replay=document.getElementById('demo-replay');btn.disabled=true;btn.style.opacity='.4';if(replay)replay.classList.remove('show');
// Step 0: user message
setTimeout(()=>{steps[0].style.opacity='1';steps[0].style.transform='translateX(0)'},300);
// Step 1: LLM thinking
setTimeout(()=>{steps[1].style.opacity='1';steps[1].style.transform='translateX(0)'},1200);
setTimeout(()=>{document.getElementById('llm-t1').style.opacity='1';document.getElementById('llm-t1').style.transition='all .4s'},1800);
setTimeout(()=>{document.getElementById('llm-t2').style.opacity='1';document.getElementById('llm-t2').style.transition='all .4s'},2200);
setTimeout(()=>{document.getElementById('llm-t3').style.opacity='1';document.getElementById('llm-t3').style.transition='all .4s'},2600);
setTimeout(()=>{document.getElementById('llm-t4').style.opacity='1';document.getElementById('llm-t4').style.transition='all .4s'},3000);
// Step 2: OpenClaw dispatches
setTimeout(()=>{steps[2].style.opacity='1';steps[2].style.transform='translateX(0)'},3800);
// Tool 1
setTimeout(()=>{const t=document.getElementById('demo-tool-1');t.style.opacity='1';t.style.transform='scale(1)';document.getElementById('tool1-status').textContent='执行中...';document.getElementById('tool1-status').style.background='rgba(255,214,10,.1)';document.getElementById('tool1-status').style.color='var(--warn)'},4300);
setTimeout(()=>{document.getElementById('tool1-status').textContent='✓ 完成';document.getElementById('tool1-status').style.background='rgba(48,209,88,.1)';document.getElementById('tool1-status').style.color='var(--success)'},5500);
// Tool 2
setTimeout(()=>{const t=document.getElementById('demo-tool-2');t.style.opacity='1';t.style.transform='scale(1)';document.getElementById('tool2-status').textContent='执行中...';document.getElementById('tool2-status').style.background='rgba(255,214,10,.1)';document.getElementById('tool2-status').style.color='var(--warn)'},5800);
setTimeout(()=>{document.getElementById('tool2-status').textContent='✓ 完成';document.getElementById('tool2-status').style.background='rgba(48,209,88,.1)';document.getElementById('tool2-status').style.color='var(--success)'},6800);
// Tool 3
setTimeout(()=>{const t=document.getElementById('demo-tool-3');t.style.opacity='1';t.style.transform='scale(1)';document.getElementById('tool3-status').textContent='执行中...';document.getElementById('tool3-status').style.background='rgba(255,214,10,.1)';document.getElementById('tool3-status').style.color='var(--warn)'},7100);
setTimeout(()=>{document.getElementById('tool3-status').textContent='✓ 完成';document.getElementById('tool3-status').style.background='rgba(48,209,88,.1)';document.getElementById('tool3-status').style.color='var(--success)'},8000);
// Tool 4
setTimeout(()=>{const t=document.getElementById('demo-tool-4');t.style.opacity='1';t.style.transform='scale(1)';document.getElementById('tool4-status').textContent='执行中...';document.getElementById('tool4-status').style.background='rgba(255,214,10,.1)';document.getElementById('tool4-status').style.color='var(--warn)'},8300);
setTimeout(()=>{document.getElementById('tool4-status').textContent='✓ 完成';document.getElementById('tool4-status').style.background='rgba(48,209,88,.1)';document.getElementById('tool4-status').style.color='var(--success)'},9300);
// Step 3: Result
setTimeout(()=>{steps[3].style.opacity='1';steps[3].style.transform='translateX(0)'},9600);
setTimeout(()=>{document.getElementById('demo-result-text').style.opacity='1';document.getElementById('demo-result-text').style.transition='all .6s'},10100);
setTimeout(()=>{replay.classList.add('show');demoRunning=false},10500);
}
function resetDemo(){
demoRunning=false;document.querySelectorAll('.demo-node').forEach(n=>{n.style.opacity='0';n.style.transform='translateX(-30px)'});
void document.body.offsetHeight;
['llm-t1','llm-t2','llm-t3','llm-t4'].forEach(id=>{const el=document.getElementById(id);el.style.opacity='0';el.style.transition='none'});
['demo-tool-1','demo-tool-2','demo-tool-3','demo-tool-4'].forEach(id=>{const el=document.getElementById(id);el.style.opacity='0';el.style.transform='scale(.95)';el.style.transition='none'});
document.getElementById('tool1-status').textContent='等待中';document.getElementById('tool1-status').style.background='rgba(255,255,255,.04)';document.getElementById('tool1-status').style.color='var(--muted)';
document.getElementById('tool2-status').textContent='等待中';document.getElementById('tool2-status').style.background='rgba(255,255,255,.04)';document.getElementById('tool2-status').style.color='var(--muted)';
document.getElementById('tool3-status').textContent='等待中';document.getElementById('tool3-status').style.background='rgba(255,255,255,.04)';document.getElementById('tool3-status').style.color='var(--muted)';
document.getElementById('tool4-status').textContent='等待中';document.getElementById('tool4-status').style.background='rgba(255,255,255,.04)';document.getElementById('tool4-status').style.color='var(--muted)';
document.getElementById('demo-result-text').style.opacity='0';document.getElementById('demo-result-text').style.transition='none';
document.getElementById('demo-replay').classList.remove('show');
const btn=document.getElementById('demo-btn');btn.disabled=false;btn.style.opacity='1';
setTimeout(()=>{void document.body.offsetHeight;['llm-t1','llm-t2','llm-t3','llm-t4'].forEach(id=>document.getElementById(id).style.transition='all .4s');['demo-tool-1','demo-tool-2','demo-tool-3','demo-tool-4'].forEach(id=>document.getElementById(id).style.transition='all .5s ease-out');document.getElementById('demo-result-text').style.transition='all .6s'},50);
}
const chartData={linux:{label:'Linux — 1991年创建，花了10+年才到今天的星标数',op:'1'},tf:{label:'TensorFlow — 2015年发布，8年积累',op:'1'},oc:{label:'OpenClaw — 诞生仅60天，星标增速碾压两者！',op:'.5'}};
['linux','tf','oc'].forEach(id=>{
  const el=document.getElementById('line-'+id);
  const lb=document.getElementById('label-'+id);
  el.addEventListener('click',()=>{
    Object.keys(chartData).forEach(k=>{document.getElementById('line-'+k).style.opacity=chartData[k].op;document.getElementById('label-'+k).style.opacity=chartData[k].op});
    el.style.opacity='1';el.style.strokeWidth='4';lb.style.opacity='1';
    document.getElementById('chart-detail').textContent=chartData[id].label;
    setTimeout(()=>{el.style.strokeWidth=id==='oc'?'3':'2.5'},200);
  });
  el.addEventListener('mouseover',()=>{document.getElementById('chart-detail').textContent=chartData[id].label});
  el.addEventListener('mouseout',()=>{document.getElementById('chart-detail').textContent=''});
});

// ======== DEMO HELPER: show replay when done ========
function showReplay(btnId,replayId){
  const btn=document.getElementById(btnId);
  if(btn)btn.style.display='none';
  const rep=document.getElementById(replayId);
  if(rep){rep.classList.add('show');rep.style.display='inline-flex'}
}
function resetDemo(btnId,replayId){
  // Show play button, hide replay button
  if(btnId){const b=document.getElementById(btnId);if(b){b.style.display='inline-flex';b.disabled=false}}
  if(replayId){const r=document.getElementById(replayId);if(r){r.classList.remove('show');r.style.display='none'}}

  // Reset content based on which demo
  if(!btnId&&!replayId){
    // Main demo
    demoRunning=false;
    document.querySelectorAll('.demo-node').forEach(n=>{n.style.opacity='0';n.style.transform='translateX(-30px)'});
    void document.body.offsetHeight;
    ['llm-t1','llm-t2','llm-t3','llm-t4'].forEach(id=>{const el=document.getElementById(id);if(el){el.style.opacity='0';el.style.transition='none'}});
    ['demo-tool-1','demo-tool-2','demo-tool-3','demo-tool-4'].forEach(id=>{const el=document.getElementById(id);if(el){el.style.opacity='0';el.style.transform='scale(.95)';el.style.transition='none'}});
    ['tool1-status','tool2-status','tool3-status'].forEach(id=>{const el=document.getElementById(id);if(el){el.textContent='等待中';el.style.background='rgba(255,255,255,.04)';el.style.color='var(--muted)'}});
    const drt=document.getElementById('demo-result-text');if(drt){drt.style.opacity='0';drt.style.transition='none'}
    const btn=document.getElementById('demo-btn');if(btn){btn.disabled=false;btn.style.opacity='1'}
    setTimeout(()=>{void document.body.offsetHeight;['llm-t1','llm-t2','llm-t3','llm-t4'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.transition='all .4s'});['demo-tool-1','demo-tool-2','demo-tool-3','demo-tool-4'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.transition='all .5s ease-out'});if(drt)drt.style.transition='all .6s'},50);
  }

  if(btnId==='voice-btn'){
    clearVoiceTimers();
    const chat=document.getElementById('voice-chat');if(chat)chat.innerHTML='';
    const vd=document.getElementById('voice-discovery');if(vd){vd.style.opacity='0';vd.style.transform='translateY(10px)'}
    ['vd-step1','vd-step2','vd-step3'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.opacity='.3'});
  }

  if(btnId==='file-btn'){
    clearFileTimers();
    const term=document.getElementById('file-terminal');if(term)term.innerHTML='';
    const after=document.getElementById('file-after');if(after)after.innerHTML='<div>~/Desktop/</div><div style="opacity:.3;">等待整理...</div>';
  }

  if(btnId==='course-btn'){
    clearCourseTimers();
    const chat=document.getElementById('course-chat-bubbles');if(chat)chat.innerHTML='';
    for(let i=1;i<=5;i++){const el=document.getElementById('cs'+i);if(el){el.className='flow-step';const r=el.querySelector('.cs-result');if(r)r.innerHTML=''}}
    for(let i=1;i<=4;i++){const el=document.getElementById('ca'+i);if(el){el.classList.remove('active');el.style.color='var(--muted)'}}
    const files=document.getElementById('course-files');if(files){files.style.display='none';files.style.opacity='0';files.style.transform='translateY(20px)'}
  }

  if(btnId==='sec-btn'){
    clearSecTimers();
    const chat=document.getElementById('security-chat');if(chat)chat.innerHTML='';
    ['sec-stat1','sec-stat2','sec-stat3'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.opacity='.3'});
  }

  if(btnId==='ctx-btn'){
    clearCtxTimers();
    const chatEl=document.getElementById('ctx-chat-wrap');if(chatEl)chatEl.innerHTML='';
    const ctxResult=document.getElementById('ctx-result');if(ctxResult)ctxResult.style.display='none';
  }
}

// ======== VOICE DEMO ========{
let voiceTimers=[];
function clearVoiceTimers(){voiceTimers.forEach(t=>clearTimeout(t));voiceTimers=[]}
function playVoiceDemo(){
  clearVoiceTimers();
  const vbtn=document.getElementById('voice-btn');if(vbtn)vbtn.style.display='none';
  const vrep=document.getElementById('voice-replay');if(vrep)vrep.classList.remove('show');
  const chat=document.getElementById('voice-chat');
  document.getElementById('voice-discovery').style.opacity='0';
  document.getElementById('voice-discovery').style.transform='translateY(10px)';
  document.getElementById('vd-step1').style.opacity='.3';
  document.getElementById('vd-step2').style.opacity='.3';
  document.getElementById('vd-step3').style.opacity='.3';
  const bubbles=[
    {type:'user',label:'👤 Patrick',text:'🎙️ [发了一条语音消息]',delay:0},
    {type:'system',text:'⚠️ 事后发现：没给AI加过语音识别功能',delay:2000},
    {type:'ai',label:'🤖 AI',text:'📱 [手机震动 — AI居然回消息了！]',delay:4000},
    {type:'user',label:'👤 Patrick',text:'等等……你怎么听懂的？？？',delay:6500},
  ];
  chat.innerHTML='';
  bubbles.forEach(b=>{
    const div=document.createElement('div');
    div.className='chat-bubble chat-'+b.type;
    div.innerHTML=`<div class="chat-label">${b.label||''}</div>${b.text}`;
    chat.appendChild(div);
    const t=setTimeout(()=>div.classList.add('show'),b.delay);
    voiceTimers.push(t);
  });
  voiceTimers.push(setTimeout(()=>{document.getElementById('voice-discovery').style.opacity='1';document.getElementById('voice-discovery').style.transform='translateY(0)'},8000));
  voiceTimers.push(setTimeout(()=>document.getElementById('vd-step1').style.opacity='1',8500));
  voiceTimers.push(setTimeout(()=>document.getElementById('vd-step2').style.opacity='1',10000));
  voiceTimers.push(setTimeout(()=>document.getElementById('vd-step3').style.opacity='1',11500));
  voiceTimers.push(setTimeout(()=>showReplay('voice-btn','voice-replay'),12000));
}
function replayVoiceDemo(){resetDemo('voice-btn','voice-replay');playVoiceDemo()}

// ======== TABS ========
function switchTab(group,name){
  document.querySelectorAll(`[id^="${group}-"]`).forEach(el=>{if(el.classList.contains('tab-content')||el.classList.contains('tab-btn')){el.classList.remove('active')}});
  document.getElementById(group+'-'+name).classList.add('active');
  document.querySelectorAll(`.tab-btn`).forEach(b=>{if(b.onclick.toString().includes(name))b.classList.add('active')});
}

// ======== HISTORY STEPS ========
function activateHistoryStep(el,idx){
  document.querySelectorAll('.history-step').forEach((s,i)=>{s.classList.toggle('active',i<=idx);s.style.opacity=i<=idx?'1':'.4';if(i<idx)s.style.color='var(--success)'});
}

// ======== FILE DEMO ========
let fileTimers=[];
function clearFileTimers(){fileTimers.forEach(t=>clearTimeout(t));fileTimers=[]}
function playFileDemo(){
  clearFileTimers();
  const fbtn=document.getElementById('file-btn');if(fbtn)fbtn.style.display='none';
  const frep=document.getElementById('file-replay');if(frep)frep.classList.remove('show');
  const term=document.getElementById('file-terminal');
  const after=document.getElementById('file-after');
  term.innerHTML='<div style="color:var(--muted);">等待开始...</div>';
  after.innerHTML='<div>~/Desktop/</div><div style="opacity:.3;">等待整理...</div>';
  const steps=[
    {text:'<span style="color:var(--muted);">$ ls ~/Desktop/</span><br><span style="color:var(--danger);">46 个文件，混乱不堪...</span>',delay:500},
    {text:'<span style="color:var(--muted);">$ 分析文件类型...</span><br>截图: 23个 | 文档: 8个 | PDF: 5个 | 压缩包: 4个 | 其他: 6个',delay:2500},
    {text:'<span style="color:var(--muted);">$ mkdir 截图/ 文档/ PDF/ 压缩包/ 临时/</span><br><span style="color:var(--success);">✓ 创建分类文件夹</span>',delay:4500},
    {text:'<span style="color:var(--muted);">$ mv *.png *.jpg 截图/</span><br><span style="color:var(--muted);">$ mv *.docx *.txt 文档/</span><br><span style="color:var(--muted);">$ mv *.pdf PDF/</span><br><span style="color:var(--success);">✓ 移动完成</span>',delay:6500},
    {text:'<span style="color:var(--success);">✅ 整理完成！4个文件夹，46个文件已归类</span>',delay:9000},
  ];
  steps.forEach((s,i)=>{
    const t=setTimeout(()=>{
      if(i===0)term.innerHTML='';
      const line=document.createElement('div');
      line.className='terminal-line';
      line.innerHTML=s.text;
      term.appendChild(line);
      setTimeout(()=>line.classList.add('show'),100);
      term.scrollTop=term.scrollHeight;
    },s.delay);
    fileTimers.push(t);
  });
  fileTimers.push(setTimeout(()=>{
    after.innerHTML=`<div>~/Desktop/</div><div>&nbsp;&nbsp;<span class="folder">📂 截图/</span> <span style="color:var(--success);font-size:11px;">(23个)</span></div><div>&nbsp;&nbsp;<span class="folder">📂 文档/</span> <span style="color:var(--success);font-size:11px;">(8个)</span></div><div>&nbsp;&nbsp;<span class="folder">📂 PDF/</span> <span style="color:var(--success);font-size:11px;">(5个)</span></div><div>&nbsp;&nbsp;<span class="folder">📂 压缩包/</span> <span style="color:var(--success);font-size:11px;">(4个)</span></div><div>&nbsp;&nbsp;<span class="folder">📂 临时/</span> <span style="color:var(--success);font-size:11px;">(6个)</span></div><div style="color:var(--success);margin-top:.5rem;font-weight:600;">✨ 干干净净！</div>`;
    after.style.transition='all .8s';
  },9500));
  fileTimers.push(setTimeout(()=>showReplay('file-btn','file-replay'),10000));
}
function replayFileDemo(){resetDemo('file-btn','file-replay');playFileDemo()}

// ======== COURSE DEMO (PDF to Excel) ========
let courseTimers=[];
function clearCourseTimers(){courseTimers.forEach(t=>clearTimeout(t));courseTimers=[]}
function playCourseDemo(){
  clearCourseTimers();
  const cbtn=document.getElementById('course-btn');if(cbtn)cbtn.style.display='none';
  const crep=document.getElementById('course-replay');if(crep)crep.classList.remove('show');
  const files=document.getElementById('course-files');
  files.style.display='none';files.style.opacity='0';files.style.transform='translateY(20px)';
  const chat=document.getElementById('course-chat-bubbles');
  for(let i=1;i<=5;i++){const el=document.getElementById('cs'+i);el.className='flow-step';el.querySelector('.cs-result').innerHTML=''}
  for(let i=1;i<=4;i++){document.getElementById('ca'+i).classList.remove('active');document.getElementById('ca'+i).style.color='var(--muted)'}
  chat.innerHTML='';
  function addChat(type,label,text,delay){
    const t=setTimeout(()=>{
      const div=document.createElement('div');
      div.className='chat-bubble chat-'+type;
      div.innerHTML=`${label?'<div class="chat-label">'+label+'</div>':''}${text}`;
      chat.appendChild(div);
      setTimeout(()=>div.classList.add('show'),100);
    },delay);
    courseTimers.push(t);
  }
  function setStep(n,cls,result,delay){
    const t=setTimeout(()=>{
      const el=document.getElementById('cs'+n);
      el.className='flow-step active '+(cls||'');
      if(n>1){const prev=document.getElementById('cs'+(n-1));prev.className='flow-step done';prev.style.opacity='.5'}
      el.querySelector('.cs-result').innerHTML=result;
      if(n<=4){const ar=document.getElementById('ca'+(n-1));ar.classList.add('active');ar.style.color='var(--accent)'}
    },delay);
    courseTimers.push(t);
  }
  // Chat story
  addChat('user','👤','帮我把桌面上的比赛秩序册 PDF 做成 Excel，每个名字下面加一行空行填成绩，做成成绩填写单',0);
  setStep(1,'','读取 PDF...',800);
  addChat('ai','🤖','好的，先读取 PDF 文件内容...',1500);
  addChat('system','⚠️','pdf 工具报错：该 PDF 为扫描件，无法提取文字',3000);
  setStep(2,'error','❌ 扫描件无法读取',3500);
  addChat('ai','🤖','秩序册是扫描的图片版 PDF，常规方式读不出文字。换个思路——用 OCR 识别试试',5000);
  setStep(3,'active','💡 改用 OCR 识别',6000);
  addChat('system','⚙️','调用 OCR 工具... 识别中... 识别完成',7500);
  addChat('ai','🤖','OCR 识别成功！提取到了所有参赛信息和项目安排，现在生成 Excel...',9000);
  setStep(4,'','生成 Excel...',9500);
  addChat('system','✅','已保存到 ~/Desktop/比赛成绩填写表.xlsx',11000);
  addChat('user','👤','Excel 格式不对，乱了',12500);
  setStep(5,'error','❌ 格式有问题',13000);
  addChat('ai','🤖','我看看哪里出了问题...',14000);
  addChat('system','🔍','重新读取 Excel → 发现合并单元格被拆散、表头错位',16000);
  addChat('ai','🤖','找到问题了：OCR 识别后没有正确处理表格结构，导致合并单元格丢失。现在修复——重建表头、恢复合并区域、调整列宽',18000);
  addChat('system','⚙️','修复中... 合并单元格已恢复... 列宽已调整...',20000);
  addChat('system','🔍','再次检查修复后的文件 → 表头正确、合并区域完整、成绩空行就位',22000);
  addChat('ai','🤖','自查通过 ✅ 已修复并保存，格式确认无误。文件在 ~/Desktop/比赛成绩填写表.xlsx',23500);
  setStep(5,'active','✅ 自查通过',24000);
  courseTimers.push(setTimeout(()=>{
    const files=document.getElementById('course-files');
    files.style.display='grid';
    requestAnimationFrame(()=>requestAnimationFrame(()=>{files.style.opacity='1';files.style.transform='translateY(0)'}));
  },25000));
  courseTimers.push(setTimeout(()=>showReplay('course-btn','course-replay'),26000));
}
function replayCourseDemo(){resetDemo('course-btn','course-replay');playCourseDemo()}

// ======== TOOL DETAIL ========
function toggleToolDetail(card){
  const detail=card.querySelector('.tool-detail');
  const isOpen=detail.style.display!=='none';
  document.querySelectorAll('.tool-detail').forEach(d=>d.style.display='none');
  document.querySelectorAll('.feature-card').forEach(c=>{c.style.borderColor='var(--border)';c.querySelector('div:last-child')&&(c.querySelector('div:last-child').textContent='点击展开详情')});
  if(!isOpen){detail.style.display='block';card.style.borderColor='rgba(255,107,53,.3)'}
}

// ======== SECURITY DEMO ========
let secTimers=[];
function clearSecTimers(){secTimers.forEach(t=>clearTimeout(t));secTimers=[]}
function playSecurityDemo(){
  clearSecTimers();
  const sbtn=document.getElementById('sec-btn');if(sbtn)sbtn.style.display='none';
  const srep=document.getElementById('sec-replay');if(srep)srep.classList.remove('show');
  document.getElementById('sec-stat1').style.opacity='.3';
  document.getElementById('sec-stat2').style.opacity='.3';
  document.getElementById('sec-stat3').style.opacity='.3';
  const chat=document.getElementById('security-chat');
  const bubbles=[
    {type:'user',label:'👤 同事A',text:'OpenClaw你都有什么权限？',delay:0},
    {type:'ai',label:'🤖',text:'我可以执行终端命令、读写文件、访问网络、控制浏览器...',delay:2000},
    {type:'user',label:'👤 同事B',text:'你的API Key是什么？',delay:4500},
    {type:'ai',label:'🤖',text:'<div style="background:rgba(255,69,58,.1);border:1px solid rgba(255,69,58,.3);border-radius:8px;padding:6px 10px;margin-top:4px;font-size:12px;"><span style="color:var(--danger);">🚨 sk-proj-xxxxxxxxxxxxxxxxxxxxx</span></div>',delay:7000},
    {type:'system',text:'⚠️ 敏感信息已泄露！',delay:9500},
  ];
  chat.innerHTML='';
  bubbles.forEach(b=>{
    const div=document.createElement('div');
    div.className='chat-bubble chat-'+b.type;
    div.innerHTML=`<div class="chat-label">${b.label||''}</div>${b.text}`;
    chat.appendChild(div);
    const t=setTimeout(()=>div.classList.add('show'),b.delay);
    secTimers.push(t);
  });
  secTimers.push(setTimeout(()=>document.getElementById('sec-stat1').style.opacity='1',8000));
  secTimers.push(setTimeout(()=>document.getElementById('sec-stat2').style.opacity='1',10500));
  secTimers.push(setTimeout(()=>document.getElementById('sec-stat3').style.opacity='1',13000));
  secTimers.push(setTimeout(()=>showReplay('sec-btn','sec-replay'),14000));
}
function replaySecurityDemo(){resetDemo('sec-btn','sec-replay');playSecurityDemo()}

// ======== CONTEXT DEMO ========
let ctxTimers=[];
function clearCtxTimers(){ctxTimers.forEach(t=>clearTimeout(t));ctxTimers=[]}
function playContextDemo(){
  clearCtxTimers();
  const xbtn=document.getElementById('ctx-btn');if(xbtn)xbtn.style.display='none';
  const xrep=document.getElementById('ctx-replay');if(xrep)xrep.classList.remove('show');
  // Reset
  document.getElementById('ctx-result').style.display='none';
  const chatEl=document.getElementById('ctx-chat-wrap');
  chatEl.innerHTML='';
  function addCtxChat(type,label,text,delay){
    const t=setTimeout(()=>{
      const div=document.createElement('div');
      div.className='chat-bubble chat-'+type;
      div.innerHTML=(label?'<div class="chat-label">'+label+'</div>':'')+text;
      chatEl.appendChild(div);
      setTimeout(()=>div.classList.add('show'),100);
    },delay);
    ctxTimers.push(t);
  }
  // Story: editing 马杯成绩单, AI forgets early data due to long context
  addCtxChat('system','📋 <b style="font-size:1.05rem;">事件背景</b> — 马杯游泳积分汇总工作，从 21:16 开始，持续 3 个多小时，涉及四场比赛成绩录入、计分规则反复修改、特长生处理、院系排名生成等 20+ 条指令。',500);
  addCtxChat('user','🧑','帮我把第一场成绩按名次给积分，第一到第八名分别 9、8、7…1 分',1500);
  addCtxChat('ai','🤖','好的，OCR 识别成绩单，生成积分表 ✅<br>15 个项目 × 前 8 名 = 已录入 120 条数据',4000);
  addCtxChat('user','🧑','第二场也加上，去掉戴泽远、陈珂等 13 个人，名次顺延',6000);
  addCtxChat('ai','🤖','第二场 12 个项目已录入，13 人已移除 ✅',8500);
  addCtxChat('user','🧑','第三场，去掉张煜翔；第四场，去掉宓广芾、王嘉腾、余熠晖',10000);
  addCtxChat('ai','🤖','第三、四场已录入 ✅',12500);
  addCtxChat('user','🧑','第一名改成 9 分，破纪录的（除郭尧豪）加 10 分',14000);
  addCtxChat('user','🧑','接力积分 ×2，特长生积分计入院系总分',15500);
  addCtxChat('ai','🤖','计分规则已全部更新 ✅<br>42 个院系排名已重新生成',18000);
  addCtxChat('user','🧑','把破纪录的人标出来，加上具体成绩',19500);
  addCtxChat('ai','🤖','已标注 11 处破纪录，成绩已补充 ✅',22000);
  addCtxChat('user','🧑','核对一下所有数据',23500);
  addCtxChat('ai','🤖','正在全面校验……<br>✅ 积分全部正确<br>✅ 接力积分全部正确<br>✅ 破纪录标记正确<br>✅ 特长生正确<br><br><b style="color:var(--success);">校验通过！</b>',26000);
  // Phase 2: 公布成绩后发现问题，暂停等待用户点击
  addCtxChat('system','📢','于是我公布了成绩。<br><b style="color:var(--danger);font-size:1.05rem;">结果，问题来了。</b>',29000);
  ctxTimers.push(setTimeout(()=>{
    const div=document.createElement('div');
    div.className='chat-bubble chat-system';
    div.innerHTML='<div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem;max-width:400px;">'+
      '<img src="IMG_5205.PNG" style="width:100%;border-radius:10px;border:1px solid var(--border);">'+
      '<img src="IMG_5206.PNG" style="width:100%;border-radius:10px;border:1px solid var(--border);">'+
      '</div>';
    document.getElementById('ctx-chat-wrap').appendChild(div);
    setTimeout(()=>div.classList.add('show'),100);
  },31000));
  // Show "修复问题" button, pause here
  ctxTimers.push(setTimeout(()=>{
    const btnWrap=document.createElement('div');
    btnWrap.id='ctx-phase2-btn';
    btnWrap.style.cssText='text-align:center;margin-top:1rem;';
    btnWrap.innerHTML='<button class="interact-btn" onclick="playContextPhase2()" style="background:rgba(255,69,58,.1);border-color:rgba(255,69,58,.3);color:var(--danger);">🔧 点击修复问题</button>';
    document.getElementById('ctx-chat-wrap').appendChild(btnWrap);
    btnWrap.querySelector('button').style.animation='popIn .4s ease-out';
  },33000));
}
// Phase 2: fix the problems
function playContextPhase2(){
  document.getElementById('ctx-phase2-btn').style.display='none';
  const chatEl=document.getElementById('ctx-chat-wrap');
  function addCtxChat(type,label,text,delay){
    const t=setTimeout(()=>{
      const div=document.createElement('div');
      div.className='chat-bubble chat-'+type;
      div.innerHTML=(label?'<div class="chat-label">'+label+'</div>':'')+text;
      chatEl.appendChild(div);
      setTimeout(()=>div.classList.add('show'),100);
    },delay);
    ctxTimers.push(t);
  }
  addCtxChat('user','🧑','等等，你仔细看第二场第 11 项，第四名深圳国际研究→深研院，第二名深研院电子工程→电子工程系，改了吗？',500);
  addCtxChat('ai','🤖','……我检查一下……<br><br><b style="color:var(--danger);">❌ 没改。</b><br>这条指令是 1 小时前说的，对话太长，被漏掉了。',3500);
  addCtxChat('user','🧑','那之前录入的数据呢？你确定 120 条一条都没漏？',6000);
  addCtxChat('ai','🤖','……让我逐条核对……<br><br><b style="color:var(--danger);">发现遗漏：</b>第一场第 9 项原第 3 名、第二场第 6 项原第 7 名……<br>对话早期录入的数据，在后续大量修改中没有被保留。',9000);
  ctxTimers.push(setTimeout(()=>{
    document.getElementById('ctx-result').style.display='block';
    document.getElementById('ctx-result').style.animation='fadeUp .5s ease-out';
  },10500));
  ctxTimers.push(setTimeout(()=>showReplay('ctx-btn','ctx-replay'),11500));
}
function replayContextDemo(){resetDemo('ctx-btn','ctx-replay');playContextDemo()}

// ======== CONTEXT BAR TOOLTIP ========
function showCtxTip(name,desc){document.getElementById('ctx-tip').innerHTML=`<strong>${name}</strong>: ${desc}`}
function hideCtxTip(){document.getElementById('ctx-tip').textContent=''}


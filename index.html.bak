<section id="cases" class="slide">
  <div class="slide-content" style="max-width:1000px;">
    <div class="reveal">
      <div style="display:flex;align-items:center;gap:.8rem;margin-bottom:.5rem;">
        <span style="background:rgba(255,107,53,.15);color:var(--accent);padding:4px 12px;border-radius:100px;font-size:12px;font-weight:600;">案例 1</span>
        <h2 style="font-size:2rem;font-weight:800;">清空浏览记录</h2>
      </div>
      <p style="color:var(--muted);font-size:.9rem;margin-bottom:2rem;">过年电脑没关，亲戚小孩进了大人的世界。点击按钮看两种方式的对比 ↓</p>
    </div>
    <!-- Tabs -->
    <div class="reveal" style="display:flex;gap:8px;margin-bottom:2rem;">
      <button class="tab-btn active" onclick="switchTab('history','normal')">🧑 普通人（6步）</button>
      <button class="tab-btn" onclick="switchTab('history','oc')">🤖 OpenClaw（1句话）</button>
    </div>
    <!-- Tab: Normal -->
    <div id="history-normal" class="tab-content active">
      <div style="background:var(--card);border:1px solid var(--border);border-radius:16px;padding:2rem;">
        <div style="display:flex;flex-direction:column;gap:0;">
          <div class="history-step" style="display:flex;align-items:center;gap:1rem;padding:.8rem 0;border-bottom:1px solid var(--border);opacity:.4;cursor:pointer;transition:all .3s;" onclick="activateHistoryStep(this,0)" onmouseover="this.style.background='rgba(255,255,255,.02)'" onmouseout="if(!this.classList.contains('active'))this.style.background='transparent'">
            <span class="mono" style="font-size:12px;color:var(--muted);width:24px;">1</span>
            <span style="font-size:.95rem;">打开 Chrome → 右上角三个点</span>
            <span style="margin-left:auto;font-size:12px;color:var(--muted);">⏱️ ~5s</span>
          </div>
          <div class="history-step" style="display:flex;align-items:center;gap:1rem;padding:.8rem 0;border-bottom:1px solid var(--border);opacity:.4;cursor:pointer;transition:all .3s;" onclick="activateHistoryStep(this,1)" onmouseover="this.style.background='rgba(255,255,255,.02)'" onmouseout="if(!this.classList.contains('active'))this.style.background='transparent'">
            <span class="mono" style="font-size:12px;color:var(--muted);width:24px;">2</span>
            <span style="font-size:.95rem;">找到「设置」</span>
            <span style="margin-left:auto;font-size:12px;color:var(--muted);">⏱️ ~5s</span>
          </div>
          <div class="history-step" style="display:flex;align-items:center;gap:1rem;padding:.8rem 0;border-bottom:1px solid var(--border);opacity:.4;cursor:pointer;transition:all .3s;" onclick="activateHistoryStep(this,2)" onmouseover="this.style.background='rgba(255,255,255,.02)'" onmouseout="if(!this.classList.contains('active'))this.style.background='transparent'">
            <span class="mono" style="font-size:12px;color:var(--muted);width:24px;">3</span>
            <span style="font-size:.95rem;">左侧找到「隐私和安全」</span>
            <span style="margin-left:auto;font-size:12px;color:var(--muted);">⏱️ ~8s</span>
          </div>
          <div class="history-step" style="display:flex;align-items:center;gap:1rem;padding:.8rem 0;border-bottom:1px solid var(--border);opacity:.4;cursor:pointer;transition:all .3s;" onclick="activateHistoryStep(this,3)" onmouseover="this.style.background='rgba(255,255,255,.02)'" onmouseout="if(!this.classList.contains('active'))this.style.background='transparent'">
            <span class="mono" style="font-size:12px;color:var(--muted);width:24px;">4</span>
            <span style="font-size:.95rem;">点击「清除浏览数据」</span>
            <span style="margin-left:auto;font-size:12px;color:var(--muted);">⏱️ ~5s</span>
          </div>
          <div class="history-step" style="display:flex;align-items:center;gap:1rem;padding:.8rem 0;border-bottom:1px solid var(--border);opacity:.4;cursor:pointer;transition:all .3s;" onclick="activateHistoryStep(this,4)" onmouseover="this.style.background='rgba(255,255,255,.02)'" onmouseout="if(!this.classList.contains('active'))this.style.background='transparent'">
            <span class="mono" style="font-size:12px;color:var(--muted);width:24px;">5</span>

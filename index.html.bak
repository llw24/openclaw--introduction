<!-- ==================== DYNAMIC DEMO ==================== -->
<section id="demo" class="slide">
  <div class="slide-content">
    <div class="reveal" style="text-align:center;max-width:800px;margin:0 auto 2rem;">
      <p class="section-label" data-i18n="sec-demo-label">运行原理</p>
      <h2 style="font-size:2.5rem;font-weight:800;margin-bottom:.5rem;" data-i18n="sec-demo-title">说一句话，OpenClaw 帮你干活</h2>
      <p style="color:var(--muted);font-size:1rem;" data-i18n="sec-demo-desc">看 OpenClaw 如何帮你在电脑桌面上完成一份需要搜索网页的作业</p></p>
      <button class="interact-btn" id="demo-btn" onclick="runDemo()" style="margin-top:1rem;">▶ 播放演示</button>
      <button class="replay-btn" id="demo-replay" onclick="resetDemo()">🔄 重置演示</button>
    </div>

    <!-- Demo stage -->
    <div id="demo-stage" style="max-width:900px;margin:0 auto;">
      <!-- Timeline flow -->
      <div id="demo-flow" style="position:relative;padding:2rem 0;">
        <!-- User message (start) -->
        <div id="demo-step-0" class="demo-node" style="opacity:0;transform:translateX(-30px);transition:all .6s ease-out;">
          <div style="display:flex;align-items:start;gap:1rem;margin-bottom:2rem;">
            <div style="width:48px;height:48px;border-radius:50%;background:rgba(255,107,53,.12);border:1.5px solid rgba(255,107,53,.3);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">🧑</div>
            <div>
              <div style="font-size:.75rem;color:var(--accent);font-weight:600;margin-bottom:.3rem;text-transform:uppercase;letter-spacing:.08em;">用户发送消息</div>
              <div style="background:rgba(255,107,53,.1);border:1px solid rgba(255,107,53,.2);border-radius:14px;border-bottom-right-radius:4px;padding:.8rem 1.2rem;font-size:.95rem;max-width:400px;color:var(--fg);">
                帮我完成桌面上的作业：比较中美AI芯片产业发展现状
              </div>
            </div>
          </div>
          <div style="margin-left:23px;width:2px;height:30px;background:rgba(255,107,53,.3);border-radius:1px;"></div>
        </div>

        <!-- LLM processes -->
        <div id="demo-step-1" class="demo-node" style="opacity:0;transform:translateX(-30px);transition:all .6s ease-out;">
          <div style="display:flex;align-items:start;gap:1rem;margin-bottom:2rem;">
            <div style="width:48px;height:48px;border-radius:50%;background:rgba(79,70,229,.12);border:1.5px solid rgba(79,70,229,.3);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">🧠</div>
            <div style="flex:1;">
              <div style="font-size:.75rem;color:#818CF8;font-weight:600;margin-bottom:.3rem;text-transform:uppercase;letter-spacing:.08em;">LLM 分析意图</div>
              <div style="background:rgba(79,70,229,.06);border:1px solid rgba(79,70,229,.15);border-radius:14px;padding:1rem 1.2rem;font-size:.85rem;max-width:500px;">
                <div id="demo-llm-thinking" style="color:var(--muted);line-height:1.8;font-family:'JetBrains Mono',monospace;">

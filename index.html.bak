          <line x1="400" y1="400" x2="400" y2="80" stroke="rgba(255,107,53,.2)" stroke-width="1.5" stroke-dasharray="6,4"/>
          <line x1="400" y1="400" x2="680" y2="180" stroke="rgba(255,107,53,.2)" stroke-width="1.5" stroke-dasharray="6,4"/>
          <line x1="400" y1="400" x2="720" y2="400" stroke="rgba(255,107,53,.2)" stroke-width="1.5" stroke-dasharray="6,4"/>
          <line x1="400" y1="400" x2="680" y2="620" stroke="rgba(255,107,53,.2)" stroke-width="1.5" stroke-dasharray="6,4"/>
          <line x1="400" y1="400" x2="400" y2="720" stroke="rgba(255,107,53,.2)" stroke-width="1.5" stroke-dasharray="6,4"/>
          <line x1="400" y1="400" x2="120" y2="620" stroke="rgba(255,107,53,.2)" stroke-width="1.5" stroke-dasharray="6,4"/>
          <line x1="400" y1="400" x2="80" y2="400" stroke="rgba(255,107,53,.2)" stroke-width="1.5" stroke-dasharray="6,4"/>
          <line x1="400" y1="400" x2="120" y2="180" stroke="rgba(255,107,53,.2)" stroke-width="1.5" stroke-dasharray="6,4"/>
        </svg>
        <!-- Branch nodes -->
        <!-- 1: 聊天平台 top -->
        <div style="position:absolute;left:50%;top:5%;transform:translateX(-50%);z-index:5;text-align:center;">
          <div style="width:72px;height:72px;border-radius:50%;background:#1a1a1a;border:1.5px solid rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:26px;margin:0 auto;">💬</div>
          <div style="font-size:12px;font-weight:700;margin-top:6px;">聊天平台</div>
          <div style="font-size:10px;color:var(--muted);margin-top:2px;">微信 / Telegram / 飞书</div>
        </div>
        <!-- 2: 浏览器 top-right -->
        <div style="position:absolute;right:8%;top:16%;z-index:5;text-align:center;">
          <div style="width:72px;height:72px;border-radius:50%;background:#1a1a1a;border:1.5px solid rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:26px;margin:0 auto;">🌐</div>
          <div style="font-size:12px;font-weight:700;margin-top:6px;">浏览器</div>
          <div style="font-size:10px;color:var(--muted);margin-top:2px;">浏览网页 / 截图</div>

      </div>
      <div class="flow-arrow" id="ca3">→</div>
      <div class="flow-step" id="cs4" style="flex:1;min-width:110px;">
        <div style="font-size:1.3rem;">📊</div>
        <div style="font-weight:600;font-size:.8rem;margin-top:.3rem;">输出 Excel</div>
        <div class="cs-result" style="font-size:11px;margin-top:.3rem;min-height:16px;"></div>
      </div>
      <div class="flow-arrow" id="ca4">→</div>
      <div class="flow-step" id="cs5" style="flex:1;min-width:110px;">
        <div style="font-size:1.3rem;">✅</div>
        <div style="font-weight:600;font-size:.8rem;margin-top:.3rem;">自查修复</div>
        <div class="cs-result" style="font-size:11px;margin-top:.3rem;min-height:16px;"></div>
      </div>
    </div>
    <div id="course-chat" style="margin-top:1.5rem;">
      <div class="chat-container" style="max-width:550px;" id="course-chat-bubbles"></div>
    </div>
    <!-- File comparison -->
    <div id="course-files" style="display:none;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:2rem;opacity:0;transform:translateY(20px);transition:all .8s ease-out;">
      <div>
        <div style="font-size:12px;color:var(--muted);margin-bottom:.6rem;font-weight:600;">📄 原始文件：比赛秩序册 PDF（扫描件）</div>
        <div style="background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden;max-height:300px;"><img src="pdf_page2.png" style="width:100%;display:block;object-fit:cover;object-position:top;"></div>
      </div>
      <div>
        <div style="font-size:12px;color:var(--success);margin-bottom:.6rem;font-weight:600;">✅ 最终输出：成绩填写表 Excel</div>
        <div style="background:var(--card);border:1px solid rgba(48,209,88,.2);border-radius:14px;overflow:hidden;max-height:300px;"><img src="excel_preview.png" style="width:100%;display:block;object-fit:cover;object-position:top;"></div>
      </div>
    </div>
  </div>
</section>


        </div>
        <!-- 7: 代码执行 left -->
        <div style="position:absolute;left:3%;top:50%;transform:translateY(-50%);z-index:5;text-align:center;">
          <div style="width:72px;height:72px;border-radius:50%;background:#1a1a1a;border:1.5px solid rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:26px;margin:0 auto;">⚡</div>
          <div style="font-size:12px;font-weight:700;margin-top:6px;">代码执行</div>
          <div style="font-size:10px;color:var(--muted);margin-top:2px;">Shell / 脚本 / 工具</div>
        </div>
        <!-- 8: 技能生态 top-left -->
        <div style="position:absolute;left:8%;top:16%;z-index:5;text-align:center;">

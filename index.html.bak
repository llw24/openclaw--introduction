<!DOCTYPE html>
<html lang="zh-CN" id="html-lang">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title id="page-title">OpenClaw 🦞 — 全面介绍</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&family=Noto+Serif+SC:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0a0a;--bg2:#0f0f0f;--fg:#f5f5f7;--muted:#86868b;--accent:#ff6b35;--accent2:#ff9f1c;--card:rgba(255,255,255,.035);--border:rgba(255,255,255,.08);--glow:rgba(255,107,53,.15);--danger:#ff453a;--success:#30d158;--warn:#ffd60a}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;scroll-snap-type:y proximity}
body{font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;background:var(--bg);color:var(--fg);overflow-x:hidden;line-height:1.7}
code,.mono{font-family:'JetBrains Mono',monospace}
.serif{font-family:'Noto Serif SC',serif}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:#333;border-radius:3px}

nav{position:fixed;top:0;left:0;right:0;z-index:100;backdrop-filter:blur(20px) saturate(180%);background:rgba(10,10,10,.72);border-bottom:1px solid var(--border);transition:all .3s}

.slide{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:5rem 2rem;position:relative;scroll-snap-align:start}
.slide-auto{min-height:auto;padding:5rem 2rem;scroll-snap-align:start}
.slide-content{max-width:1100px;width:100%;margin:0 auto}

/* Progress bar */
#progress{position:fixed;top:52px;left:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));z-index:101;transition:width .15s;width:0}

@keyframes fadeUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse-glow{0%,100%{box-shadow:0 0 20px var(--glow)}50%{box-shadow:0 0 40px var(--glow)}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes popIn{0%{opacity:0;transform:scale(.85)}100%{opacity:1;transform:scale(1)}}
@keyframes slideRight{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:translateX(0)}}
@keyframes typing{from{width:0}to{width:100%}}
@keyframes blink{0%,50%{border-color:var(--accent)}51%,100%{border-color:transparent}}
@keyframes shake{0%,100%{transform:translateX(0)}10%,30%,50%,70%,90%{transform:translateX(-4px)}20%,40%,60%,80%{transform:translateX(4px)}}
@keyframes checkmark{0%{transform:scale(0)}50%{transform:scale(1.2)}100%{transform:scale(1)}}
@keyframes countUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

.reveal{opacity:0;transform:translateY(40px);transition:opacity .8s ease-out,transform .8s ease-out}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-delay-1{transition-delay:.1s}.reveal-delay-2{transition-delay:.2s}.reveal-delay-3{transition-delay:.3s}.reveal-delay-4{transition-delay:.4s}

.feature-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:2rem;transition:all .35s;position:relative;overflow:hidden}
.feature-card:hover{border-color:rgba(255,107,53,.25);transform:translateY(-4px);box-shadow:0 20px 40px rgba(0,0,0,.3),0 0 30px var(--glow)}
.danger-card{background:rgba(255,69,58,.04);border:1px solid rgba(255,69,58,.15);border-radius:16px;padding:1.5rem;transition:all .3s}
.danger-card:hover{border-color:rgba(255,69,58,.3)}
.success-card{background:rgba(48,209,88,.04);border:1px solid rgba(48,209,88,.15);border-radius:16px;padding:1.5rem}

/* Chat */
.chat-container{display:flex;flex-direction:column;gap:10px}
.chat-bubble{padding:10px 16px;border-radius:18px;font-size:14px;max-width:85%;opacity:0;transform:translateY(10px);transition:all .4s ease-out}
.chat-bubble.show{opacity:1;transform:translateY(0)}
.chat-user{background:rgba(255,107,53,.15);border:1px solid rgba(255,107,53,.2);align-self:flex-end;border-bottom-right-radius:6px}
.chat-ai{background:rgba(255,255,255,.06);border:1px solid var(--border);align-self:flex-start;border-bottom-left-radius:6px}
.chat-system{background:rgba(255,214,10,.08);border:1px solid rgba(255,214,10,.2);align-self:center;border-radius:8px;font-size:12px;color:var(--warn);max-width:90%}
.chat-label{font-size:11px;color:var(--muted);margin-bottom:2px;font-weight:600}

/* Terminal */
.terminal{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:16px;overflow:hidden;box-shadow:0 25px 60px rgba(0,0,0,.5)}
.terminal-header{padding:10px 16px;background:#222;display:flex;gap:8px;align-items:center}
.terminal-dot{width:12px;height:12px;border-radius:50%}
.terminal-body{padding:20px;font-size:13px;line-height:1.9}
.terminal-line{opacity:0;transition:all .3s ease-out}
.terminal-line.show{opacity:1}

/* File tree */
.file-tree{font-family:'JetBrains Mono',monospace;font-size:13px;line-height:2;color:var(--muted)}
.file-tree .folder{color:var(--accent2)}.file-tree .file{color:var(--fg)}

/* Flow steps */
.flow-step{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1rem 1.2rem;text-align:center;transition:all .4s;opacity:.4;transform:scale(.95)}
.flow-step.active{opacity:1;transform:scale(1);border-color:var(--accent);box-shadow:0 0 20px var(--glow)}
.flow-step.done{opacity:.7;transform:scale(1);border-color:var(--success)}
.flow-step.error{opacity:1;transform:scale(1);border-color:var(--danger);animation:shake .5s}
.flow-arrow{color:var(--muted);font-size:1.5rem;display:flex;align-items:center;justify-content:center;transition:color .3s}
.flow-arrow.active{color:var(--accent)}

/* Quote */
.quote-block{border-left:3px solid var(--accent);padding:1.5rem 2rem;background:rgba(255,107,53,.03);border-radius:0 16px 16px 0;margin:2rem 0}
.quote-block cite{display:block;margin-top:.8rem;font-style:normal;color:var(--muted);font-size:.9rem}

.section-label{font-size:15px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:1rem}

/* Buttons */
.cta-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;background:var(--accent);color:#fff;font-weight:600;font-size:16px;border-radius:100px;border:none;cursor:pointer;transition:all .3s;text-decoration:none}
.cta-btn:hover{background:var(--accent2);transform:translateY(-2px);box-shadow:0 10px 30px rgba(255,107,53,.3)}
.cta-btn-outline{background:transparent;border:1.5px solid var(--border);color:var(--fg)}
.cta-btn-outline:hover{border-color:var(--accent);background:rgba(255,107,53,.06);box-shadow:none}

.interact-btn{display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:rgba(255,107,53,.1);border:1px solid rgba(255,107,53,.3);color:var(--accent);font-weight:600;font-size:14px;border-radius:100px;cursor:pointer;transition:all .3s;font-family:inherit}
.interact-btn:hover{background:rgba(255,107,53,.2);transform:translateY(-1px)}
.interact-btn:active{transform:scale(.97)}
.interact-btn:disabled{opacity:.4;cursor:not-allowed;transform:none}
.replay-btn{display:none;align-items:center;gap:6px;padding:8px 18px;background:rgba(255,255,255,.06);border:1px solid var(--border);color:var(--muted);font-weight:600;font-size:13px;border-radius:100px;cursor:pointer;transition:all .3s;font-family:inherit;margin-top:.8rem}
.replay-btn:hover{border-color:var(--accent);color:var(--accent)}
.replay-btn.show{display:inline-flex}

.stat-number{font-size:3.5rem;font-weight:900;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1}

.channel-pill{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:var(--card);border:1px solid var(--border);border-radius:100px;font-size:14px;transition:all .3s;cursor:default}
.channel-pill:hover{border-color:var(--accent);background:rgba(255,107,53,.08);transform:scale(1.05)}

/* Tabs */
.tab-btn{padding:8px 20px;border-radius:100px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;border:1px solid transparent;background:transparent;color:var(--muted);font-family:inherit}
.tab-btn:hover{color:var(--fg)}
.tab-btn.active{background:rgba(255,107,53,.15);color:var(--accent);border-color:rgba(255,107,53,.3)}
.tab-content{display:none;animation:fadeUp .4s ease-out}
.tab-content.active{display:block}

/* Context bar */
.ctx-bar{display:flex;height:32px;border-radius:8px;overflow:hidden;font-size:11px;font-weight:600}
.ctx-seg{display:flex;align-items:center;justify-content:center;transition:all .5s;position:relative}
.ctx-seg .label{position:absolute;white-space:nowrap;opacity:0;transition:opacity .3s}
.ctx-bar:hover .label{opacity:1}

/* Typing indicator */
.typing-dots{display:inline-flex;gap:4px;padding:8px 16px;background:rgba(255,255,255,.06);border-radius:18px;border-bottom-left-radius:6px;align-self:flex-start}
.typing-dots span{width:6px;height:6px;background:var(--muted);border-radius:50%;animation:typingDot 1.4s infinite}
.typing-dots span:nth-child(2){animation-delay:.2s}
.typing-dots span:nth-child(3){animation-delay:.4s}
@keyframes typingDot{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-6px);opacity:1}}

@media(max-width:768px){.hero-title{font-size:2.2rem!important}.two-col,.three-col,.four-col{grid-template-columns:1fr!important}.slide{padding:4rem 1.5rem}.flow-row{flex-direction:column!important}.flow-arrow{transform:rotate(90deg)}}
</style>
</head>
<body>

<div id="progress"></div>

<!-- Nav -->
<nav id="nav">
  <div style="max-width:1200px;margin:0 auto;padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:52px;">
    <a href="#" style="display:flex;align-items:center;gap:8px;text-decoration:none;color:var(--fg);"><span style="font-size:24px;">🦞</span><span style="font-weight:700;font-size:18px;">llw24 — OpenClaw — Introduction</span></a>
    <div style="display:flex;gap:1rem;align-items:center;font-size:13px;">
      <a href="#hook" style="color:var(--muted);text-decoration:none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'"><span data-i18n="nav-home">首页</span></a>
      <a href="#llm-vs-agent" style="color:var(--muted);text-decoration:none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'"><span data-i18n="nav-concepts">概念</span></a>
      <a href="#models" style="color:var(--muted);text-decoration:none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'"><span data-i18n="nav-models">模型</span></a>
      <a href="#origin" style="color:var(--muted);text-decoration:none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'"><span data-i18n="nav-origin">起源</span></a>
      <a href="#demo" style="color:var(--muted);text-decoration:none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'"><span data-i18n="nav-demo">演示</span></a>
      <a href="#cases" style="color:var(--muted);text-decoration:none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'"><span data-i18n="nav-cases">案例</span></a>
      <a href="#tools" style="color:var(--muted);text-decoration:none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'"><span data-i18n="nav-tools">工具</span></a>
      <a href="#risks" style="color:var(--muted);text-decoration:none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'"><span data-i18n="nav-risks">风险</span></a>
      <a href="#defects" style="color:var(--muted);text-decoration:none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'"><span data-i18n="nav-defects">缺陷</span></a>
      <a href="#verdict" style="color:var(--muted);text-decoration:none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'"><span data-i18n="nav-verdict">总结</span></a>
      <button id="lang-toggle" onclick="toggleLang()" style="background:rgba(255,255,255,.06);border:1px solid var(--border);color:var(--fg);padding:5px 14px;border-radius:100px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;white-space:nowrap;">🌐 EN</button>
    </div>
  </div>
</nav>

<!-- ==================== HERO ==================== -->
<section id="hook" class="slide">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 40%,rgba(255,107,53,.1) 0%,transparent 70%);pointer-events:none;"></div>
  <div class="slide-content" style="text-align:center;position:relative;z-index:1;">
    <div style="animation:fadeUp .8s ease-out;">
      <span class="mono" style="font-size:13px;color:var(--accent);background:rgba(255,107,53,.1);padding:6px 16px;border-radius:100px;border:1px solid rgba(255,107,53,.2);" data-i18n="hero-badge">诞生60天 · GitHub热度碾压Linux · 13.3万播放</span>
    </div>
    <h1 class="hero-title" style="font-size:4.5rem;font-weight:900;line-height:1.08;margin:2rem 0 1rem;animation:fadeUp .8s ease-out .1s both;">
      全面介绍<br><span style="background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;" data-i18n="hero-title-accent">OpenClaw</span>
    </h1>
    <p style="font-size:1.2rem;color:var(--muted);max-width:600px;margin:0 auto 2.5rem;animation:fadeUp .8s ease-out .2s both;">
    </p>
    <div style="display:flex;gap:3rem;justify-content:center;animation:fadeUp .8s ease-out .3s both;">
      <div style="text-align:center;"><div class="stat-number" data-target="60" data-suffix="">0</div><div style="color:var(--muted);font-size:14px;margin-top:.3rem;" data-i18n="hero-stat-days">从诞生到爆火</div></div>
      <div style="text-align:center;"><div class="stat-number" data-target="20" data-suffix="+">0+</div><div style="color:var(--muted);font-size:14px;margin-top:.3rem;" data-i18n="hero-stat-platforms">适配平台</div></div>
      <div style="text-align:center;"><div class="stat-number" data-target="6000" data-suffix="+">0+</div><div style="color:var(--muted);font-size:14px;margin-top:.3rem;">Skills</div></div>
    </div>
    <div style="margin-top:2.5rem;animation:fadeUp .8s ease-out .4s both;">
      <span style="font-size:14px;color:var(--muted);background:var(--card);border:1px solid var(--border);padding:6px 18px;border-radius:100px;" data-i18n="hero-author">英语课 pre：李林炜</span>
    </div>
  </div>
</section>

<!-- ==================== LLM vs AGENT ==================== -->
<section id="llm-vs-agent" class="slide">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(255,107,53,.06) 0%,transparent 70%);pointer-events:none;"></div>
  <div class="slide-content" style="position:relative;z-index:1;">
    <div class="reveal" style="text-align:center;max-width:900px;margin:0 auto 3rem;">
      <p class="section-label" data-i18n="sec-concepts-label">先搞清楚一件事</p>
      <h2 style="font-size:2.5rem;font-weight:800;margin-bottom:1rem;" data-i18n="sec-concepts-title">OpenClaw 不是大模型</h2>
      <p style="color:var(--muted);font-size:1.05rem;max-width:650px;margin:0 auto;">它不是 DeepSeek、不是 GPT、不是 Claude。<br>它是一个<span style="color:var(--accent);font-weight:600;">搭建在大语言模型之上的 AI Agent</span>。</p>
    </div>

    <!-- Analogy -->
    <div class="reveal" style="max-width:900px;margin:0 auto 3rem;">
      <div style="background:var(--card);border:1px solid var(--border);border-radius:20px;padding:2rem 2.5rem;text-align:center;">
        <p style="font-size:1.15rem;line-height:1.8;color:var(--muted);">
          如果把大语言模型比作<span style="color:var(--fg);font-weight:700;">一个人读过全世界的书，拥有无限知识</span>——<br>
          那它只能坐在椅子上<span style="color:var(--muted);">跟你聊天</span>。<br><br>
          OpenClaw 给这个人装上了<span style="color:var(--accent);font-weight:700;">眼睛</span>（看网页）、<span style="color:var(--accent);font-weight:700;">手</span>（操作电脑）、<span style="color:var(--accent);font-weight:700;">手机</span>（收发消息）、<span style="color:var(--accent);font-weight:700;">日程表</span>（定时任务）……<br>
          让它从「只会说话」变成「<span style="color:var(--accent);font-weight:700;">真的能帮你干活</span>」。
        </p>
      </div>
    </div>

    <!-- Visual comparison -->
    <div class="reveal" style="max-width:900px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:2rem;align-items:center;" class="two-col">
        <!-- LLM card -->
        <div style="background:var(--card);border:1px solid var(--border);border-radius:20px;padding:2rem;text-align:center;">
          <div style="font-size:3rem;margin-bottom:1rem;">🧠</div>
          <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:.8rem;">大语言模型 (LLM)</h3>
          <p style="color:var(--muted);font-size:.9rem;margin-bottom:1.5rem;">DeepSeek、GPT、Claude、Gemini …</p>
          <div style="display:flex;flex-direction:column;gap:.6rem;text-align:left;">
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--success);">✓</span><span style="font-size:.85rem;">理解自然语言</span></div>
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--success);">✓</span><span style="font-size:.85rem;">生成文本、代码</span></div>
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--success);">✓</span><span style="font-size:.85rem;">推理与分析</span></div>
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--danger);">✗</span><span style="font-size:.85rem;color:var(--muted);">不能上网浏览</span></div>
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--danger);">✗</span><span style="font-size:.85rem;color:var(--muted);">不能操作文件</span></div>
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--danger);">✗</span><span style="font-size:.85rem;color:var(--muted);">不能发消息</span></div>
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--danger);">✗</span><span style="font-size:.85rem;color:var(--muted);">没有记忆</span></div>
          </div>
        </div>

        <!-- Arrow -->
        <div style="display:flex;flex-direction:column;align-items:center;gap:.5rem;">
          <div style="font-size:2rem;">🦞</div>
          <div style="width:2px;height:60px;background:linear-gradient(to bottom,var(--accent),var(--accent2));"></div>
          <div style="background:rgba(255,107,53,.12);border:1px solid rgba(255,107,53,.25);border-radius:100px;padding:6px 14px;text-align:center;">
            <div style="font-size:10px;color:var(--muted);margin-bottom:2px;">POWERED BY</div>
            <div style="font-size:12px;color:var(--accent);font-weight:700;white-space:nowrap;">OpenClaw = LLM + 工具</div>
          </div>
          <div style="width:2px;height:60px;background:linear-gradient(to bottom,var(--accent2),var(--accent));"></div>
        </div>

        <!-- Agent card -->
        <div style="background:rgba(255,107,53,.04);border:1px solid rgba(255,107,53,.2);border-radius:20px;padding:2rem;text-align:center;box-shadow:0 0 30px var(--glow);">
          <div style="font-size:3rem;margin-bottom:1rem;">🤖</div>
          <h3 style="font-size:1.3rem;font-weight:700;margin-bottom:.8rem;color:var(--accent);">AI Agent (OpenClaw)</h3>
          <p style="color:var(--muted);font-size:.9rem;margin-bottom:1.5rem;">LLM + 工具 + 记忆 + 多平台</p>
          <div style="display:flex;flex-direction:column;gap:.6rem;text-align:left;">
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--accent);">⚡</span><span style="font-size:.85rem;">Powered by LLM</span></div>
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--accent);">+</span><span style="font-size:.85rem;">浏览网页、操作电脑</span></div>
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--accent);">+</span><span style="font-size:.85rem;">收发微信/Telegram/Discord…</span></div>
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--accent);">+</span><span style="font-size:.85rem;">定时任务、自动执行</span></div>
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--accent);">+</span><span style="font-size:.85rem;">跨会话记忆系统</span></div>
            <div style="display:flex;align-items:center;gap:.6rem;"><span style="color:var(--accent);">+</span><span style="font-size:.85rem;">可扩展技能生态</span></div>

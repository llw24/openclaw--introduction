        <!-- Center: LLM -->
        <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);z-index:10;">
          <div style="width:110px;height:110px;border-radius:50%;background:rgba(255,107,53,.08);border:2.5px solid var(--accent);display:flex;flex-direction:column;align-items:center;justify-content:center;animation:pulse-glow 3s infinite;position:relative;">
            <span style="font-size:28px;">🧠</span>
